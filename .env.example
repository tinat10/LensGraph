# ─── Database (Neon — recommended) ───────────────────────────────────────────
#
# 1. Sign up free at https://neon.tech
# 2. Create a project (name it "lensgraph")
# 3. Open Dashboard → Connect → copy the connection string
# 4. Paste it below (keep sslmode=require if Neon includes it)
#
# Example:
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# ─── Auth (NextAuth / Auth.js) ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# GitHub OAuth — create at https://github.com/settings/developers
AUTH_GITHUB_ID="your-github-oauth-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-client-secret"

# Google OAuth (optional) — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
# AUTH_GOOGLE_ID="your-google-client-id"
# AUTH_GOOGLE_SECRET="your-google-client-secret"

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── OpenAI (optional — AI captions, tags, mood, semantic search) ─────────────
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
# OPENAI_VISION_MODEL="gpt-4o-mini"
# OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# ─── Mapbox (optional — GPS reverse geocoding) ───────────────────────────────
# Create a token at https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN="pk...."

# ─── OpenWeather (optional — weather on published story pages) ───────────────
# Get a key at https://openweathermap.org/api
OPENWEATHER_API_KEY="your-openweather-key"
